// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// Notes - stored in the Notes section
model Note {
  id        String   @id @default(cuid())
  title     String   @default("Untitled")
  content   String   @default("")
  icon      String   @default("📄")
  order     Int      @default(0)
  archived  Boolean  @default(false)
  parentId  String?
  parent    Note?    @relation("NoteToNote", fields: [parentId], references: [id], onDelete: Cascade)
  children  Note[]   @relation("NoteToNote")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Vault items - K/V store for quick reference
model VaultItem {
  id        String   @id @default(cuid())
  key       String   
  value     String   @default("")
  tags      String   @default("") // comma-separated tags for filtering
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Memories - photos, videos, journal entries
model Memory {
  id        String   @id @default(cuid())
  title     String   @default("Untitled")
  content   String   @default("")
  icon      String   @default("📸")
  type      String   @default("journal") // photo, video, journal
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
